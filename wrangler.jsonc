{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  "name": "describe",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],

  // Enable observability for better debugging
  "observability": {
    "enabled": true
  },

  // Durable Object binding
  "durable_objects": {
    "bindings": [
      { "name": "KLADOS_JOB", "class_name": "KladosJobDO" }
    ]
  },

  // SQL storage for DO (required for SQL-backed DOs)
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["KladosJobDO"] }
  ],

  // Environment variables (non-secret)
  // Note: For multi-network support, we use the production agent ID here.
  // The worker reads request.network to handle both test and main.
  "vars": {
    "AGENT_ID": "01KJ60TTR9BACEJHH5WGW2H10C",
    "AGENT_ID_TEST": "IIKHM05BX9NKE0S24TZCDKWFDF",
    "AGENT_ID_MAIN": "01KJ60TTR9BACEJHH5WGW2H10C",
    "AGENT_VERSION": "1.0.0"
  }

  // Secrets (set via `wrangler secret put`):
  // - ARKE_AGENT_KEY: Default agent API key (fallback)
  // - ARKE_AGENT_KEY_TEST: Test network klados key (ak_4317c05...)
  // - ARKE_AGENT_KEY_MAIN: Main network klados key (ak_80c696d...)
  // - GEMINI_API_KEY: Your Gemini API key
}
